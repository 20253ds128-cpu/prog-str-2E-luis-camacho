<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.*?>

<VBox spacing="15"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.luiscamacho.logindashboard.controllers.LoginController">

    <children>
        <Label text="Login"/>
        <TextField fx:id="txtEmail" promptText="Correo"/>
        <PasswordField fx:id="txtPassword" promptText="Contraseña"/>
        <Button text="Ingresar" onAction="#handleLogin"/>
    </children>

</VBox>