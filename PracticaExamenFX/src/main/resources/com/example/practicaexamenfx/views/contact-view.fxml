<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" alignment="CENTER"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.practicaexamenfx.controllers.ContactController">



    <Label text="Contactos de Emergencia"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Nombre:" GridPane.rowIndex="0"/>
        <TextField fx:id="txtNombre" GridPane.columnIndex="1"/>

        <Label text="Teléfono:" GridPane.rowIndex="1"/>
        <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Parentesco:" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cbParentesco" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <ListView fx:id="listViewContactos" prefHeight="150"/>

    <HBox spacing="10">
        <Button text="Agregar" onAction="#onAddContact"/>
        <Button text="Buscar" onAction="#onBuscar"/>
        <Button text="Actualizar" onAction="#onActualizar"/>
        <Button text="Eliminar" onAction="#onEliminar"/>
        <Button text="Limpiar" onAction="#onLimpiar"/>
    </HBox>

</VBox>